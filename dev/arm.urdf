<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="30" length="20"/>
      </geometry>
      <origin xyz="0 0 10" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Joint 1 -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 20" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.14159" effort="5" velocity="1.0"/>
  </joint>

  <link name="link1">
    <visual>
      <geometry>
        <cylinder radius="15" length="167.719"/>
      </geometry>
      <origin xyz="0 0 83.8595" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Joint 2: lower arm -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 167.719" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.570795" upper="1.570795" effort="5" velocity="1.0"/>
  </joint>

  <link name="link2">
    <visual>
      <geometry>
        <cylinder radius="10" length="250.201"/>
      </geometry>
      <origin xyz="0 0 125.1005" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.2 0.4 1.0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Joint 3: upper arm -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 250.201" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.356195" upper="2.356195" effort="5" velocity="1.0"/>
  </joint>

  <link name="link3">
    <visual>
      <geometry>
        <cylinder radius="10" length="177.485"/>
      </geometry>
      <origin xyz="0 0 88.7425" rpy="0 0 0"/>
      <material name="green">
        <color rgba="0.0 0.8 0.3 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Joint 4 : Wrist -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 177.485" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="5" velocity="1.0"/>
  </joint>

  <link name="link4">
    <visual>
      <geometry>
        <cylinder radius="10" length="54.70"/>
      </geometry>
      <origin xyz="0 0 27.35" rpy="0 0 0"/>
      <material name="orange">
        <color rgba="0.9 0.5 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Joint 5 -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 54.70" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.356195" upper="2.356195" effort="5" velocity="1.0"/>
  </joint>

  <link name="link5">
    <visual>
      <geometry>
        <cylinder radius="7" length="95.069"/>
      </geometry>
      <origin xyz="0 0 47.5345" rpy="0 0 0"/>
      <material name="yellow">
        <color rgba="0.9 0.9 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Joint 6 -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 95.069" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="5" velocity="1.0"/>
  </joint>

  <link name="link6">
    <visual>
      <geometry>
        <cylinder radius="6" length="100"/>
      </geometry>
      <origin xyz="0 0 50" rpy="0 0 0"/>
      <material name="red">
        <color rgba="0.9 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

</robot>
